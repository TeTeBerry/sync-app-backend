# Copy to .env and adjust: cp .env.example .env

# Server
PORT=3000
# CORS_ORIGINS=http://localhost:10086,http://127.0.0.1:10086

# Required
MONGODB_URI=mongodb://127.0.0.1:27017/sync

# Optional — leave empty for local dev without Docker
# Heat cache + distributed AI rate limits; empty → Mongo + in-memory fallback
REDIS_URL=
# REDIS_URL=redis://127.0.0.1:6379

# Required for AI chat / agents
QWEN_API_KEY=
QWEN_MODEL=qwen-turbo
QWEN_RERANK_MODEL=qwen-plus
QWEN_RERANK_TIMEOUT_MS=6000
QWEN_VL_MODEL=qwen-vl-plus

# Optional — vector RAG; empty → Mongo/rules matching (post_recommendations may be degraded)
CHROMA_URL=
# CHROMA_URL=http://localhost:8000
CHROMA_COLLECTION=sync_knowledge
CHROMA_POSTS_COLLECTION=sync_posts
CHROMA_PROFILES_COLLECTION=sync_user_profiles
# Legacy local path (ignored unless it is an http(s) URL)
# CHROMA_PATH=./chroma_data

# Infra helpers (see package.json)
# npm run infra:up        # mongo + redis
# npm run infra:chroma    # chroma on :8000
