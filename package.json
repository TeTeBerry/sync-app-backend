{
  "name": "sync-app-backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "stop:dev": "node scripts/kill-port.mjs 3000",
    "start:dev": "npm run stop:dev && nest build && nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "infra:up": "docker compose up -d mongo redis",
    "infra:up:cn": "MONGO_IMAGE=docker.m.daocloud.io/library/mongo:7 REDIS_IMAGE=docker.m.daocloud.io/library/redis:7-alpine docker compose up -d mongo redis",
    "infra:chroma": "docker compose --profile chroma up -d chroma",
    "infra:down": "docker compose down",
    "wait:mongo": "node scripts/wait-for-port.mjs localhost 27017 90000 MongoDB",
    "db:reset": "node scripts/reset-test-data.mjs",
    "db:sync-catalog": "node scripts/sync-activity-catalog.mjs",
    "dev": "npm run wait:mongo && npm run stop:dev && nest build && nest start --watch",
    "dev:all": "npm run infra:up:cn && npm run wait:mongo && npm run stop:dev && nest build && nest start --watch",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@langchain/community": "^0.2.10",
    "@langchain/core": "^0.2.10",
    "@nestjs/common": "^7.0.0",
    "@nestjs/config": "^0.6.3",
    "@nestjs/core": "^7.0.0",
    "@nestjs/mongoose": "^7.2.4",
    "@nestjs/platform-express": "^7.0.0",
    "chromadb": "^1.10.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "ioredis": "^5.4.1",
    "mongoose": "^5.13.23",
    "reflect-metadata": "^0.1.13",
    "rimraf": "^3.0.2",
    "rxjs": "^6.6.7",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^9.5.0",
    "@nestjs/schematics": "^9.2.0",
    "@nestjs/testing": "^7.0.0",
    "@types/express": "^4.17.3",
    "@types/jest": "25.1.4",
    "@types/node": "^13.9.1",
    "@types/supertest": "^2.0.8",
    "@typescript-eslint/eslint-plugin": "^4.33.0",
    "@typescript-eslint/parser": "^4.33.0",
    "eslint": "^6.8.0",
    "eslint-config-prettier": "^6.10.0",
    "eslint-plugin-import": "^2.20.1",
    "jest": "^25.1.0",
    "prettier": "^1.19.1",
    "supertest": "^4.0.2",
    "ts-jest": "25.2.1",
    "ts-loader": "^6.2.1",
    "ts-node": "^8.6.2",
    "tsconfig-paths": "^3.9.0",
    "typescript": "^4.9.5"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".spec.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
