{
  "name": "sync-app-backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "postbuild": "node scripts/sync-contract-dist.mjs",
    "clean:contracts": "rm -rf packages/*/dist",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "typecheck:scripts": "tsc -p tsconfig.scripts.json --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "stop:dev": "node scripts/kill-port.mjs 3000",
    "start:dev": "npm run stop:dev && nest build && nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main",
    "infra:up": "docker compose up -d mongo redis",
    "infra:up:cn": "MONGO_IMAGE=docker.m.daocloud.io/library/mongo:7 REDIS_IMAGE=docker.m.daocloud.io/library/redis:7-alpine docker compose up -d mongo redis",
    "infra:chroma": "docker compose --profile chroma up -d chroma",
    "infra:chroma:cn": "CHROMA_IMAGE=docker.m.daocloud.io/chromadb/chroma:0.5.23 docker compose --profile chroma up -d chroma",
    "infra:down": "docker compose down",
    "wait:mongo": "node scripts/wait-for-port.mjs localhost 27017 90000 MongoDB",
    "wait:chroma": "node scripts/wait-for-port.mjs localhost 8000 90000 Chroma",
    "db:reset": "node scripts/reset-test-data.mjs",
    "db:sync-catalog": "node scripts/sync-activity-catalog.mjs",
    "db:sync-catalog:all": "node scripts/sync-activity-catalog-all.mjs",
    "db:clean-dirty": "node scripts/clean-dirty-data.mjs",
    "db:clean-dirty:dry-run": "node scripts/clean-dirty-data.mjs --dry-run",
    "db:migrate-partner": "node scripts/migrate-partner-legacy.mjs",
    "db:migrate-partner:dry-run": "node scripts/migrate-partner-legacy.mjs --dry-run",
    "db:reset-attendees": "node scripts/reset-attendees.mjs",
    "db:reset-attendees:dry-run": "node scripts/reset-attendees.mjs --dry-run",
    "db:seed-itinerary": "node scripts/seed-itinerary-catalog.mjs",
    "db:seed-tml-mock-posts": "node -r ts-node/register -r tsconfig-paths/register scripts/seed-tml-mock-posts.ts",
    "db:seed-ops-buddy-posts": "node -r ts-node/register -r tsconfig-paths/register scripts/seed-ops-buddy-posts.ts",
    "db:backfill-user-avatars": "node -r ts-node/register -r tsconfig-paths/register scripts/backfill-user-avatars.ts",
    "db:backfill-user-avatars:dry-run": "node -r ts-node/register -r tsconfig-paths/register scripts/backfill-user-avatars.ts --dry-run",
    "db:sync-personality-test": "node scripts/sync-personality-test-catalog.mjs",
    "media:upload-personality-test": "node scripts/upload-personality-test-media.mjs",
    "media:upload-raver-avatars": "node scripts/upload-raver-avatars.mjs",
    "media:upload-activity-images": "node scripts/sync-activity-images-cloud.mjs",
    "media:sync-activity-images": "node scripts/sync-activity-images-cloud.mjs",
    "db:crawl-catalog-artists": "node scripts/crawl-discogs-catalog-artists.mjs",
    "db:crawl-defqon-artists": "node scripts/crawl-discogs-catalog-artists.mjs -- --activity-legacy-id 2",
    "db:crawl-edc-orlando-artists": "node scripts/crawl-discogs-catalog-artists.mjs -- --activity-legacy-id 13",
    "db:crawl-ultra-europe-artists": "node scripts/crawl-discogs-catalog-artists.mjs -- --activity-legacy-id 15",
    "db:crawl-world-dj-festival-artists": "node scripts/crawl-discogs-catalog-artists.mjs -- --activity-legacy-id 6",
    "db:sync-lineup-artist-catalog:all": "node scripts/sync-lineup-artist-catalog-all.mjs",
    "db:sync-lineup-avatars": "node scripts/sync-lineup-artist-avatars-cloud.mjs --missing-only",
    "db:sync-defqon-avatars": "node scripts/sync-lineup-artist-avatars-cloud.mjs --missing-only --activity-legacy-id 2",
    "db:sync-lineup-avatars:dry-run": "node scripts/sync-lineup-artist-avatars-cloud.mjs --missing-only --dry-run",
    "db:report-lineup-avatar-gaps": "node scripts/report-lineup-avatar-gaps.mjs",
    "db:report-defqon-gaps": "node scripts/report-defqon-artist-gaps.mjs",
    "db:report-defqon-gaps:json": "node scripts/report-defqon-artist-gaps.mjs -- --write-json",
    "db:translate-dj-locale": "node scripts/translate-dj-locale.mjs",
    "db:translate-dj-locale:all": "node scripts/translate-dj-locale-all.mjs",
    "db:sync-dj-profile-locale:all": "node scripts/sync-dj-profile-locale-all.mjs",
    "dev": "npm run wait:mongo && npm run stop:dev && nest build && nest start --watch",
    "dev:all": "npm run infra:up:cn && npm run infra:chroma:cn && npm run wait:mongo && npm run wait:chroma && npm run stop:dev && nest build && nest start --watch",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm test",
    "openapi:generate": "npm run build && node scripts/generate-openapi.cjs",
    "openapi:check": "npm run openapi:generate && git diff --exit-code openapi/openapi.json",
    "prepare": "husky",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "smoke:api": "node scripts/smoke-api.mjs",
    "smoke:api:wait": "node scripts/wait-for-port.mjs localhost 3000 90000 API && node scripts/smoke-api.mjs",
    "smoke:golden": "node scripts/smoke-golden.mjs",
    "smoke:golden:wait": "node scripts/wait-for-port.mjs localhost 3000 90000 API && node scripts/smoke-golden.mjs",
    "smoke:suite": "node scripts/smoke-golden.mjs",
    "smoke:suite:wait": "node scripts/wait-for-port.mjs localhost 3000 90000 API && npm run smoke:suite"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@langchain/core": "^0.2.10",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/mongoose": "^10.1.0",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/swagger": "^7.4.2",
    "@sync/activity-contracts": "*",
    "@sync/chat-contracts": "*",
    "@sync/festival-plan-contracts": "*",
    "@sync/itinerary-contracts": "*",
    "@sync/notification-contracts": "*",
    "@sync/partner-contracts": "*",
    "@sync/profile-contracts": "*",
    "@sync/scene-contracts": "*",
    "@sync/travel-guide-contracts": "*",
    "@sync/travel-plan-contracts": "*",
    "chromadb": "^3.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dayjs": "^1.11.21",
    "form-data": "^4.0.5",
    "ioredis": "^5.4.1",
    "mongoose": "^7.8.6",
    "reflect-metadata": "^0.2.2",
    "rimraf": "^5.0.10",
    "rxjs": "^7.8.1",
    "uuid": "^11.0.5",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.14",
    "@types/supertest": "^6.0.2",
    "@types/ws": "^8.5.13",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^15.4.3",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testMatch": [
      "<rootDir>/test/unit/**/*.spec.ts",
      "<rootDir>/test/contract/**/*.spec.ts"
    ],
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "moduleNameMapper": {
      "^@src/(.*)$": "<rootDir>/src/$1",
      "^@sync/chat-contracts$": "<rootDir>/packages/chat-contracts/index.ts",
      "^@sync/chat-contracts/(.*)$": "<rootDir>/packages/chat-contracts/$1",
      "^@sync/travel-plan-contracts$": "<rootDir>/packages/travel-plan-contracts/index.ts",
      "^@sync/travel-plan-contracts/(.*)$": "<rootDir>/packages/travel-plan-contracts/$1",
      "^@sync/travel-guide-contracts$": "<rootDir>/packages/travel-guide-contracts/index.ts",
      "^@sync/travel-guide-contracts/(.*)$": "<rootDir>/packages/travel-guide-contracts/$1",
      "^@sync/partner-contracts$": "<rootDir>/packages/partner-contracts/index.ts",
      "^@sync/partner-contracts/(.*)$": "<rootDir>/packages/partner-contracts/$1",
      "^@sync/itinerary-contracts$": "<rootDir>/packages/itinerary-contracts/index.ts",
      "^@sync/itinerary-contracts/(.*)$": "<rootDir>/packages/itinerary-contracts/$1",
      "^@sync/festival-plan-contracts$": "<rootDir>/packages/festival-plan-contracts/index.ts",
      "^@sync/festival-plan-contracts/(.*)$": "<rootDir>/packages/festival-plan-contracts/$1",
      "^@sync/activity-contracts$": "<rootDir>/packages/activity-contracts/index.ts",
      "^@sync/activity-contracts/(.*)$": "<rootDir>/packages/activity-contracts/$1",
      "^@sync/notification-contracts$": "<rootDir>/packages/notification-contracts/index.ts",
      "^@sync/notification-contracts/(.*)$": "<rootDir>/packages/notification-contracts/$1",
      "^@sync/profile-contracts$": "<rootDir>/packages/profile-contracts/index.ts",
      "^@sync/profile-contracts/(.*)$": "<rootDir>/packages/profile-contracts/$1",
      "^@sync/scene-contracts$": "<rootDir>/packages/scene-contracts/index.ts",
      "^@sync/scene-contracts/(.*)$": "<rootDir>/packages/scene-contracts/$1"
    },
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.spec.ts"
    ],
    "testEnvironment": "node"
  }
}
